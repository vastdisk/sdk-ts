{
  "name": "@vastdisk/sdk-ts",
  "version": "0.2.0",
  "description": "VASTDISK client-side crypto SDK - AES-256-GCM encryption, BLAKE3 hashing, Ed25519 proof verification. Browser-native Web Crypto + @noble/hashes.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0-or-later",
  "repository": "https://github.com/vastdisk/sdk-ts",
  "keywords": [
    "vastdisk",
    "encryption",
    "aes-256-gcm",
    "ed25519",
    "blake3",
    "e2ee",
    "crypto",
    "browser"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0"
  }
}
